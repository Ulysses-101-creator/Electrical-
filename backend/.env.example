# --- App ---
APP_NAME="ElectricQuote AI API"
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- CORS (comma-separated origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Database ---
DATABASE_URL=postgresql+asyncpg://electricquote:electricquote@localhost:5432/electricquote
DATABASE_URL_SYNC=postgresql+psycopg2://electricquote:electricquote@localhost:5432/electricquote
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth / JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_HASH_PEPPER=CHANGE_ME_IN_PRODUCTION

# --- Rate limiting ---
RATE_LIMIT_DEFAULT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_AI_PER_MINUTE=10

# --- Object storage (S3-compatible) ---
STORAGE_ENDPOINT_URL=
STORAGE_BUCKET_NAME=electricquote-assets
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_REGION=us-east-1
STORAGE_PUBLIC_BASE_URL=

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Email (transactional) ---
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=quotes@electricquote.ai

# --- SMS / OTP ---
SMS_PROVIDER_API_KEY=
SMS_PROVIDER_FROM_NUMBER=

# --- Frontend ---
FRONTEND_BASE_URL=http://localhost:5173
